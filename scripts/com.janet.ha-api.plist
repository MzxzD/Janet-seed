<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.janet.ha-api</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd "$HOME/Documents/Janet-Projects/JanetOS/janet-seed" &amp;&amp; exec /usr/bin/python3 start_ha_api.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/janet-ha-api.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/janet-ha-api.err</string>
    <key>WorkingDirectory</key>
    <string>/tmp</string>
</dict>
</plist>
