      "id": "websocket_protocol_design",
      "name": "WebSocket Client-Server Protocol",
      "category": "communication",
      "date_discovered": "2026-02-28",
      "status": "active",
      "description": "JSON-based WebSocket protocol for real-time bidirectional communication",
      "protocol_version": "1.0",
      "message_types": {
        "client_to_server": [
          "user_message - Send user input to Janet",
          "end_conversation - Request summary and storage",
          "get_green_vault_summaries - Request cached summaries",
          "heartbeat - Keep connection alive"
        ],
        "server_to_client": [
          "janet_response - Janet's reply to user",
          "summary - Conversation summary after 'Thank you, Janet!'",
          "summaries - List of Green Vault summaries",
          "heartbeat_ack - Heartbeat acknowledgment"
        ]
      },
      "usage": "Foundation for all real-time Janet communication across devices"
    },
    {
      "id": "split_brain_memory",
      "name": "Split-Brain Memory Architecture",
      "category": "memory_management",
      "date_discovered": "2026-02-28",
      "status": "active",
      "description": "Distributed memory model with ephemeral device context and authoritative server memory",
      "architecture": {
        "device_tier": {
          "name": "Ephemeral Context",
          "storage": "Device memory (UserDefaults)",
          "contents": "Current conversation only",
          "persistence": "Cleared after 'Thank you, Janet!'",
          "size": "Small (<1 MB)"
        },
        "cache_tier": {
          "name": "Cached Summaries",
          "storage": "Device memory (UserDefaults)",
          "contents": "Distilled summaries from Green Vault",
          "persistence": "Synced from server",
          "size": "Medium (~5-10 MB)"
        },
        "vault_tier": {
          "name": "Green Vault (Authoritative)",
          "storage": "Server (SQLite + ChromaDB)",
          "contents": "Full conversation history",
          "persistence": "Permanent",
          "size": "Unlimited"
        }
      },
      "benefits": [
        "Minimal device storage requirements",
        "Fast local access to recent context",
        "Offline access to summaries",
        "Single source of truth (server)",
        "Privacy (full history never on device)",
        "Scalability (devices stay lightweight)"
      ],
      "usage": "Enables Janet to work on resource-constrained devices while maintaining full memory on server"
    }
